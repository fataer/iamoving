document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('email-modal');
    const form = document.getElementById('email-capture-form');
    
    // Mostrar el modal (funcionalidad existente)
    setTimeout(() => {
        modal.classList.add('show');
        document.body.classList.add('modal-open');
    }, 500);

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // 1. Recoger TODOS los campos (email + UTM)
        const formData = {
            email: document.getElementById('capture-email').value,
            utm_source: document.getElementById('utm_source').value,
            utm_ad: document.getElementById('utm_ad').value,
            utm_placement: document.getElementById('utm_placement').value
        };

        // 2. Trasladar email al formulario principal (funcionalidad existente)
        const mainEmailInput = document.getElementById('email');
        if (mainEmailInput) {
            mainEmailInput.value = formData.email;
        }

        // 3. Enviar todos los datos incluyendo UTM
        fetch('/save-email', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
                'Accept': 'application/json'
            },
            body: JSON.stringify(formData)
        })
        .then(response => {
            if (!response.ok) throw new Error('Error en la respuesta');
            return response.json();
        })
        .then(data => {
            if (data.success) {
                // Mantener funcionalidad de cierre
                modal.classList.remove('show');
                document.body.classList.remove('modal-open');
                window.scrollTo({ top: 0, behavior: 'smooth' }); // Scroll suave
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error al guardar el email. Por favor, inténtelo de nuevo.'); // Manejo de error existente
        });
    });

    // Botón de cierre (funcionalidad existente)
    const closeButton = document.createElement('button');
    closeButton.innerHTML = '×';
    closeButton.style.cssText = `
        position: absolute;
        top: 10px;
        right: 10px;
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        padding: 5px 10px;
    `;
    
    closeButton.addEventListener('click', () => {
        modal.classList.remove('show');
        document.body.classList.remove('modal-open');
    });
    
    document.querySelector('.modal-content').appendChild(closeButton);
});
</script>
