// Función autoejecutable para capturar UTMs inmediatamente
(function() {
    // Capturar los parámetros UTM de la URL
    const urlParams = new URLSearchParams(window.location.search);
    
    // 1. Capturar parámetros UTM de la URL
    const utmData = {
        utm_source: urlParams.get('utm_source') || '',
        utm_ad: urlParams.get('utm_ad') || '',
        utm_placement: urlParams.get('utm_placement') || ''
    };

    // Guardar en localStorage
    localStorage.setItem('utm_params', JSON.stringify(utmData));

    // Enviar los datos al servidor inmediatamente
    fetch('/aterrizaje', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
        },
        body: JSON.stringify(utmData) // Envía los UTM directamente
    })
    .then(response => response.json())
    .catch(error => console.error('Error guardando UTM:', error));
})();
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Obtener UTMs de localStorage
    const utmParams = JSON.parse(localStorage.getItem('utm_params') || '{}');
    
    // 2. Asignar valores a los campos ocultos
    document.getElementById('utm_source').value = utmParams.utm_source || '';
    document.getElementById('utm_ad').value = utmParams.utm_ad || '';
    document.getElementById('utm_placement').value = utmParams.utm_placement || '';
});
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const urlParams = new URLSearchParams(window.location.search);
    const isExternalReferral = urlParams.has('ref');
    const modal = document.getElementById('email-modal');
    
    // Limpiar todas las clases y estilos del modal y body
    if (isExternalReferral) {
        // 1. Eliminar completamente el modal del DOM
        if (modal) modal.parentNode.removeChild(modal);
        
        // 2. Restaurar scroll del body
        document.body.style.overflow = 'auto';
        document.body.style.position = 'static';
        document.body.style.height = 'auto';
        
        // 3. Mostrar formulario con scroll mejorado
        const consultaForm = document.getElementById('consultaForm');
        if (consultaForm) {
            consultaForm.style.display = 'block';
            setTimeout(() => {
                window.scrollTo({
                    top: consultaForm.offsetTop - 20,
                    behavior: 'smooth'
                });
            }, 50);
        }
    } else {
        // Comportamiento normal del modal
        setTimeout(() => {
            if (modal) {
                modal.classList.add('show');
                document.body.classList.add('modal-open');
            }
        }, 500);
    }
    // Verificar si hay un hash en la URL
    // 4. Código original que ya tenías
    // Verificar hash en URL
    if(window.location.hash) {
        const hash = window.location.hash.substring(1);
        if(hash === 'agendarConsulta' && consultaForm) {
            consultaForm.style.display = 'block';
            document.getElementById('agendarConsulta').scrollIntoView({
                behavior: 'smooth'
            });
        }
    }
});
</script>
