{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.1.3",
        "anhskohbo/no-captcha": "^3.1",
        "barryvdh/laravel-debugbar": "^3.2",
        "barryvdh/laravel-dompdf": "^0.8.1",
        "biscolab/laravel-recaptcha": "^4.4",
        "facebook/php-business-sdk": "^16.0",
        "fideloper/proxy": "^4.0",
        "google/recaptcha": "^1.2",
        "guzzlehttp/guzzle": "^6.5",
        "intervention/image": "^2.7",
        "klaviyo/php-sdk": "^2.3",
        "laravel/framework": "5.7.*",
        "laravel/passport": "^7.2",
        "laravel/tinker": "^1.0",
        "mpdf/mpdf": "^8.2",
        "phpmailer/phpmailer": "^6.10",
        "phpoffice/phpspreadsheet": "1.29.0",
        "phpoffice/phpword": "^1.3",
        "stripe/stripe-php": "^15.7",
        "tcg/voyager": "^1.1",
        "tecnickcom/tcpdf": "^6.9",
        "tymon/jwt-auth": "1.0.0-rc.3",
        "yajra/laravel-datatables": "^1.4",
        "yajra/laravel-datatables-oracle": "^8.13"
    },
    "require-dev": {
        "beyondcode/laravel-dump-server": "^1.0",
        "filp/whoops": "^2.0",
        "fzaninotto/faker": "^1.4",
        "mockery/mockery": "^1.0",
        "nunomaduro/collision": "^2.0",
        "phpunit/phpunit": "^7.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": false
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
    "files": [
        "app/Helpers/InmuebleHelper.php"
    ],
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "repositories": {
        "hooks": {
            "type": "composer",
            "url": "https://larapack.io"
        }
    }
}
